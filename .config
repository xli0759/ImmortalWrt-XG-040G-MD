# ==============================================================================
# 目标系统与硬件平台 (两份配置共有)
# ==============================================================================
CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_airoha_an7581_DEVICE_bell_xg-040g-md=y
CONFIG_ARCH_64BIT=y
CONFIG_aarch64=y
CONFIG_LINUX_6_12=y

# Airoha 芯片相关硬件驱动 (第一份配置提供，第二份共有)
CONFIG_PACKAGE_kmod-phy-airoha-en8811h=y
CONFIG_PACKAGE_kmod-i2c-an7581=y
# 【来自第二份配置】Airoha 风扇/PWM控制驱动
CONFIG_PACKAGE_kmod-pwm-airoha=y

# ==============================================================================
# 基础核心底座系统 (第一份配置核心，部分第二份共有)
# ==============================================================================
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_DEFAULT_base-files=y
CONFIG_DEFAULT_busybox=y
# 允许自定义 Busybox 工具箱
CONFIG_BUSYBOX_CUSTOM=y
# 启用 Busybox 的 devmem 内存查看命令
CONFIG_BUSYBOX_CONFIG_DEVMEM=y
# 启用内核 /dev/mem 设备节点支持
CONFIG_KERNEL_DEVMEM=y
# SSL/HTTPS 根证书集合
CONFIG_DEFAULT_ca-bundle=y
# 系统日志守护进程
CONFIG_DEFAULT_logd=y
# 系统 init 和服务管理核心
CONFIG_DEFAULT_procd=y
# 统一配置接口管理工具
CONFIG_DEFAULT_uci=y
# 系统随机 seeds 保存
CONFIG_DEFAULT_urandom-seed=y
# 用户空间随机数生成器
CONFIG_DEFAULT_urngd=y
# 网络接口配置管理核心
CONFIG_DEFAULT_netifd=y
# 闪存分区读写工具
CONFIG_DEFAULT_mtd=y
# 文件系统及挂载核心包
CONFIG_DEFAULT_fstools=y
CONFIG_DEFAULT_libc=y
CONFIG_DEFAULT_libgcc=y
# U-Boot 环境变量修改工具
CONFIG_PACKAGE_uboot-envtools=y
# U-Boot NVRAM 内核模块支持
CONFIG_PACKAGE_kmod-ubootenv-nvram=y
# 轻量级命令行下载工具 (类似 wget)
CONFIG_PACKAGE_uclient-fetch=y
# GPIO 按键热插拔监听
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
# GPIO LED 灯光控制
CONFIG_PACKAGE_kmod-leds-gpio=y
# UBI 闪存管理工具集
CONFIG_PACKAGE_ubi-utils=y
# 内核 UBI 闪存支持
CONFIG_MTD_UBI=y
# 内核 UBIFS 文件系统支持
CONFIG_UBIFS_FS=y
# OpenWrt 固件元数据工具
CONFIG_PACKAGE_fwtool=y

# ==============================================================================
# 网络协议、基本拨号与基础防火墙 (第一份配置)
# ==============================================================================
# DNS/DHCP 核心服务
CONFIG_PACKAGE_dnsmasq=y
# 完整版 ip 命令工具
CONFIG_PACKAGE_ip-full=y
# 全局内核 IPv6 栈支持
CONFIG_IPV6=y
# IPv6 DHCP 客户端
CONFIG_DEFAULT_odhcp6c=y
# 仅 IPv6 的内网 DHCP 广播服务器
CONFIG_DEFAULT_odhcpd-ipv6only=y
# 现代网络数据包过滤工具
CONFIG_PACKAGE_nftables=y
# 基于 nftables 的防火墙 v4
CONFIG_PACKAGE_firewall4=y
# 网桥过滤内核模块
CONFIG_PACKAGE_kmod-br-netfilter=y
# Netlink 过滤接口内核模块
CONFIG_PACKAGE_kmod-nfnetlink=y
# nftables 核心内核模块
CONFIG_PACKAGE_kmod-nft-core=y
# nftables NAT 转发内核模块
CONFIG_PACKAGE_kmod-nft-nat=y
# 软件流量分流核心模块
CONFIG_PACKAGE_kmod-nf-flow=y
# 网卡硬件流控/加速控制模块
CONFIG_PACKAGE_kmod-nft-offload=y
# 【来自第二份配置】完整版网络物理层速率诊断工具
CONFIG_PACKAGE_ethtool-full=y
# 拨号协议支持
CONFIG_PACKAGE_ppp=y
# 宽带 PPPoE 拨号客户端
CONFIG_PACKAGE_ppp-mod-pppoe=y
# 基础 SSH 登录服务
CONFIG_PACKAGE_dropbear=y
# 优化 Dropbear 占用体积
CONFIG_DROPBEAR_SMALL_CODE=y
# 开启更安全的 ED25519 秘钥支持
CONFIG_DROPBEAR_ED25519=y
# 开启更安全的 CURVE25519 秘钥支持
CONFIG_DROPBEAR_CURVE25519=y

# ==============================================================================
# 包管理器 apk (第一份配置提供，第二份共有)
# ==============================================================================
CONFIG_PACKAGE_apk=y
# apk 软件包管理器
CONFIG_DEFAULT_apk-tools=y
# apk 包验证加密插件
CONFIG_PACKAGE_apk-mbedtls=y
# 签名验证密钥环
CONFIG_DEFAULT_openwrt-keyring=y

# ==============================================================================
# USB 设备基础支持与外接 USB 2.5G 网卡驱动 (第一份提供基础，【第二份配置】补充网卡驱动)
# ==============================================================================
# 启用 USB 硬件总线支持
CONFIG_USB_SUPPORT=y
# USB 核心驱动模块
CONFIG_PACKAGE_kmod-usb-core=y
# USB 2.0 控制器模块
CONFIG_PACKAGE_kmod-usb2=y
# USB 3.0 控制器模块
CONFIG_PACKAGE_kmod-usb3=y
# USB XHCI 标准控制器驱动
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
# 联发科/Airoha 芯片专属 XHCI 驱动
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y
# USB 存储设备驱动 (U盘/移动硬盘)
CONFIG_PACKAGE_kmod-usb-storage=y
# USB UAS 高速存储协议支持
CONFIG_PACKAGE_kmod-usb-storage-uas=y
# 其他各类 USB 存储协议扩展
CONFIG_PACKAGE_kmod-usb-storage-extras=y

# --- 【以下网卡驱动及工具完全来自第二份配置】 ---
# 支持 2.5G 网口扩展 (Realtek RTL8152/8153/8156/8156B)
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
# CDC 工业标准以太网卡芯片驱动
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
# CDC NCM 高速共享以太网卡芯片驱动
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
# lsusb 命令行 USB 设备检测工具
CONFIG_PACKAGE_usbutils=y

# ==============================================================================
# 存储、挂载、多文件系统与物理分区工具 (大部分来自【第二份配置】)
# ==============================================================================
# 固件 FIT 镜像块设备挂载器
CONFIG_PACKAGE_fitblk=y
# blkid 磁盘分区 UUID 检测工具
CONFIG_PACKAGE_blkid=y
# lsblk 命令行磁盘列表查看工具
CONFIG_PACKAGE_lsblk=y
# ext4 文件系统分区及检测工具
CONFIG_PACKAGE_e2fsprogs=y

# --- 【以下文件系统驱动与工具完全来自第二份配置】 ---
# btrfs 文件系统内核模块
CONFIG_PACKAGE_kmod-fs-btrfs=y
# exfat 文件系统内核模块
CONFIG_PACKAGE_kmod-fs-exfat=y
# ext4 经典文件系统内核模块
CONFIG_PACKAGE_kmod-fs-ext4=y
# f2fs 闪存优化文件系统内核模块
CONFIG_PACKAGE_kmod-fs-f2fs=y
# 内核级 SMB (Samba) 共享服务端驱动
CONFIG_PACKAGE_kmod-fs-ksmbd=y
# msdos 传统文件系统内核模块
CONFIG_PACKAGE_kmod-fs-msdos=y
# 网络文件系统公共内核驱动模块
CONFIG_PACKAGE_kmod-fs-netfs=y
# 微软 NTFS 读写驱动 (Paragon 高性能版)
CONFIG_PACKAGE_kmod-fs-ntfs3=y
# SMB 共享公共协议核心模块
CONFIG_PACKAGE_kmod-fs-smbfs-common=y
# vfat (FAT32) 文件系统内核模块
CONFIG_PACKAGE_kmod-fs-vfat=y
# FUSE 用户空间文件系统挂载驱动
CONFIG_PACKAGE_kmod-fuse=y
# FAT32 格式化与修复工具
CONFIG_PACKAGE_dosfstools=y
# exFAT 文件系统一致性检测修复工具
CONFIG_PACKAGE_exfat-fsck=y
# exFAT 文件系统格式化工具
CONFIG_PACKAGE_exfat-mkfs=y
# f2fs 文件系统管理工具
CONFIG_PACKAGE_f2fs-tools=y
# f2fs 坏块检测及修复工具
CONFIG_PACKAGE_f2fsck=y
# FUSE v3 标准用户态挂载辅助程序
CONFIG_PACKAGE_fuse3-utils=y
# btrfs 文件系统管理维护工具
CONFIG_PACKAGE_btrfs-progs=y
# f2fs 格式化工具
CONFIG_PACKAGE_mkf2fs=y
# parted 专业大容量磁盘分区管理工具
CONFIG_PACKAGE_parted=y
# ntfs3 内核驱动挂载脚本支持
CONFIG_PACKAGE_ntfs3-mount=y
# ext2/3/4 分区无损扩容收缩工具
CONFIG_PACKAGE_resize2fs=y
# 允许 parted 命令行使用 tab 补全
CONFIG_PARTED_READLINE=y

# ==============================================================================
# 系统基础增强与命令行运维工具 (大部分来自【第二份配置】)
# ==============================================================================
# 自动分配CPU核心和温度频率读取
CONFIG_PACKAGE_autocore=y
# 自动挂载外接 USB 存储设备
CONFIG_PACKAGE_automount=y
# 基础块设备挂载系统
CONFIG_PACKAGE_block-mount=y

# --- 【以下辅助包完全来自第二份配置】 ---
# 全局通用 SSL 安全根证书
CONFIG_PACKAGE_ca-certificates=y
# Web 辅助上传/下载脚本接口
CONFIG_PACKAGE_cgi-io=y
# GNU 标准核心系统命令集合
CONFIG_PACKAGE_coreutils=y
# coreutils 的 base64 编解码命令
CONFIG_PACKAGE_coreutils-base64=y
# coreutils 的 nohup 后台不挂断运行命令
CONFIG_PACKAGE_coreutils-nohup=y
# 完整版 curl 命令行网络请求工具
CONFIG_PACKAGE_curl=y
# 支持 SSL 加密的 wget 独立包
CONFIG_PACKAGE_wget-ssl=y
# zip 压缩包解压程序
CONFIG_PACKAGE_unzip=y
# 7z 高压缩比解压与压缩程序
CONFIG_PACKAGE_7z=y
# 易用性极佳的轻量级文本编辑器
CONFIG_PACKAGE_nano=y
# 彩色可视化进程、CPU、内存监控工具
CONFIG_PACKAGE_htop=y
# 允许 htop 读取硬件传感器温度
CONFIG_HTOP_LMSENSORS=y
# 硬盘 S.M.A.R.T 健康度寿命检测工具
CONFIG_PACKAGE_smartmontools=y
# TCP 端口联通性测试工具
CONFIG_PACKAGE_tcping=y
# 基础局域网网络唤醒命令行工具
CONFIG_PACKAGE_etherwake=y
# Perl 语言编写的多功能网络唤醒工具
CONFIG_PACKAGE_wakeonlan=y
# 快速域名 IP 解析命令行工具
CONFIG_PACKAGE_resolveip=y
# OpenWrt 远程过程调用守护进程
CONFIG_PACKAGE_rpcd=y
# rpcd 文件操作扩展包
CONFIG_PACKAGE_rpcd-mod-file=y
# rpcd 无线网卡参数诊断接口
CONFIG_PACKAGE_rpcd-mod-iwinfo=y
# rpcd 与 LuCI 后台数据传输总线
CONFIG_PACKAGE_rpcd-mod-luci=y
# rpcd 硬件资源统计模块
CONFIG_PACKAGE_rpcd-mod-rpcsys=y
# rpcd 域名快速缓存模块
CONFIG_PACKAGE_rpcd-mod-rrdns=y
# rpcd 对 ucode 脚本引擎的底层调用
CONFIG_PACKAGE_rpcd-mod-ucode=y
# ucode 的 HTML 文本模板解析器
CONFIG_PACKAGE_ucode-mod-html=y
# ucode 日志输出驱动
CONFIG_PACKAGE_ucode-mod-log=y
# ucode 与 Lua 脚本互通驱动
CONFIG_PACKAGE_ucode-mod-lua=y
# ucode 高级数学计算模块
CONFIG_PACKAGE_ucode-mod-math=y
# 内网 mDNS/设备名发现广播守护进程
CONFIG_PACKAGE_umdns=y
# MTD 闪存分区临时写锁定解锁驱动
CONFIG_PACKAGE_kmod-mtd-rw=y

# ==============================================================================
# 系统底层加密、解密与性能加速支持 (完全来自【第二份配置】)
# ==============================================================================
# ASN.1 密钥格式解码内核驱动
CONFIG_PACKAGE_kmod-asn1-decoder=y
# 硬件异步数据压缩解压引擎
CONFIG_PACKAGE_kmod-crypto-acompress=y
# 高速 BLAKE2b 哈希加密算法内核模块
CONFIG_PACKAGE_kmod-crypto-blake2b=y
# 适用于 WPA3 等无线安全的 CCM 加密驱动
CONFIG_PACKAGE_kmod-crypto-ccm=y
# 现代网络加密核心 ChaCha20-Poly1305 引擎
CONFIG_PACKAGE_kmod-crypto-chacha20poly1305=y
# CMAC 数据完整性验证机制驱动
CONFIG_PACKAGE_kmod-crypto-cmac=y
# 内核级高速 crc32 硬件校验加速
CONFIG_PACKAGE_kmod-crypto-crc32=y
# 内核级对称算法 CTR 工作模式驱动
CONFIG_PACKAGE_kmod-crypto-ctr=y
# 内核级标准 deflate 压缩数据算法
CONFIG_PACKAGE_kmod-crypto-deflate=y
# 传统 DES 内核加密模块
CONFIG_PACKAGE_kmod-crypto-des=y
# 现代 AES-GCM 加密工作模式驱动
CONFIG_PACKAGE_kmod-crypto-gcm=y
# 硬件随机初始向量生成器驱动
CONFIG_PACKAGE_kmod-crypto-geniv=y
# 硬件 128 位乘法加速驱动
CONFIG_PACKAGE_kmod-crypto-gf128=y
# GHASH 高速哈希计算驱动
CONFIG_PACKAGE_kmod-crypto-ghash=y
# 内核级标准 MD5 摘要算法驱动
CONFIG_PACKAGE_kmod-crypto-md5=y
# 顺序初始向量生成器 (网络协议安全加速)
CONFIG_PACKAGE_kmod-crypto-seqiv=y
# 标准 SHA256 哈希计算内核级加速
CONFIG_PACKAGE_kmod-crypto-sha256=y
# 超高速非加密哈希算法 xxhash 内核级支持
CONFIG_PACKAGE_kmod-crypto-xxhash=y
# 网络连接链路层底层诊断驱动
CONFIG_PACKAGE_kmod-inet-diag=y
# Netlink 协议族底层诊断驱动
CONFIG_PACKAGE_kmod-netlink-diag=y
# 网络层原始套接字透明代理驱动支持
CONFIG_PACKAGE_kmod-nf-socket=y
# 防火墙 TPROXY 透明代理基础底层驱动
CONFIG_PACKAGE_kmod-nf-tproxy=y
# nftables socket 套接字数据包路由匹配驱动
CONFIG_PACKAGE_kmod-nft-socket=y
# nftables TPROXY 透明代理防火墙联动驱动
CONFIG_PACKAGE_kmod-nft-tproxy=y
# SCSI 存储设备通用抽象控制底层模块
CONFIG_PACKAGE_kmod-scsi-generic=y
# 经典 TCP BBR 拥塞控制算法 (大幅提升高延迟线路带宽)
CONFIG_PACKAGE_kmod-tcp-bbr=y
# 虚拟网卡通道 TUN/TAP 基础底层驱动
CONFIG_PACKAGE_kmod-tun=y

# ==============================================================================
# 底层静态连接库与依赖 (完全来自【第二份配置】)
# ==============================================================================
CONFIG_PACKAGE_libatomic=y
CONFIG_PACKAGE_libattr=y
CONFIG_PACKAGE_libbpf=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-ng=y
CONFIG_PACKAGE_libcomerr=y
CONFIG_PACKAGE_libcurl=y
CONFIG_PACKAGE_libe2p=y
CONFIG_PACKAGE_libelf=y
CONFIG_PACKAGE_libext2fs=y
CONFIG_PACKAGE_libf2fs=y
CONFIG_PACKAGE_libfuse3=y
CONFIG_PACKAGE_libiwinfo=y
CONFIG_PACKAGE_libiwinfo-data=y
CONFIG_PACKAGE_libltdl=y
CONFIG_PACKAGE_liblua=y
CONFIG_PACKAGE_liblua5.4=y
CONFIG_PACKAGE_liblucihttp=y
CONFIG_PACKAGE_liblucihttp-lua=y
CONFIG_PACKAGE_liblucihttp-ucode=y
CONFIG_PACKAGE_liblzo=y
CONFIG_PACKAGE_libminiupnpc=y
CONFIG_PACKAGE_libnatpmp=y
CONFIG_PACKAGE_libnghttp2=y
CONFIG_PACKAGE_libnl-core=y
CONFIG_PACKAGE_libnl-genl=y
CONFIG_PACKAGE_libparted=y
CONFIG_PACKAGE_libpcre2=y
CONFIG_PACKAGE_libreadline=y
CONFIG_PACKAGE_libss=y
CONFIG_PACKAGE_libstdcpp=y
CONFIG_PACKAGE_libubus-lua=y
CONFIG_PACKAGE_libuci-lua=y
CONFIG_PACKAGE_libuv=y
CONFIG_PACKAGE_libwebsockets-full=y
CONFIG_PACKAGE_libzstd=y
CONFIG_PACKAGE_lua=y
CONFIG_PACKAGE_kmod-oid-registry=y
CONFIG_PACKAGE_kmod-lib-crc16=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_PACKAGE_kmod-lib-lz4-decompress=y
CONFIG_PACKAGE_kmod-lib-lz4hc=y
CONFIG_PACKAGE_kmod-lib-lzo=y
CONFIG_PACKAGE_kmod-lib-raid6=y
CONFIG_PACKAGE_kmod-lib-xor=y
CONFIG_PACKAGE_kmod-lib-xxhash=y
CONFIG_PACKAGE_kmod-lib-zlib-deflate=y
CONFIG_PACKAGE_kmod-lib-zlib-inflate=y
CONFIG_PACKAGE_kmod-lib-zstd=y

# ==============================================================================
# CPU 性能跑分测试工具 (完全来自【第二份配置】)
# ==============================================================================
# 经典 CPU 整数性能测试工具
CONFIG_PACKAGE_coremark=y
# 启用多线程跑分模式
CONFIG_COREMARK_ENABLE_MULTITHREADING=y
# 针对 AN7581 分配线程数
CONFIG_COREMARK_NUMBER_OF_THREADS=16
# 采用 O3 级最高编译器优化编译跑分程序
CONFIG_COREMARK_OPTIMIZE_O3=y

# ==============================================================================
# LuCI Web UI 基础、多语言包、管理页与 Argon 主题 (两份共有，【第二份】补充多语言配置)
# ==============================================================================
# 启动 LuCI 主页
CONFIG_PACKAGE_luci=y
# 启用 LuCI HTTPS 安全加密访问
CONFIG_PACKAGE_luci-ssl=y
# LuCI 基础页面运行时环境
CONFIG_PACKAGE_luci-base=y
# 兼容旧版本插件的运行时兼容层
CONFIG_PACKAGE_luci-compat=y
# 轻量版 LuCI 基础底座
CONFIG_PACKAGE_luci-light=y
# LuCI 后台 Lua 代码运行引擎
CONFIG_PACKAGE_luci-lua-runtime=y
# LuCI 标准底层函数库
CONFIG_PACKAGE_luci-lib-base=y
# LuCI IP 地址处理计算函数库
CONFIG_PACKAGE_luci-lib-ip=y
# LuCI JSON 编解码处理库
CONFIG_PACKAGE_luci-lib-jsonc=y
# LuCI 通用系统底层接口封装库
CONFIG_PACKAGE_luci-lib-nixio=y
# LuCI 网页版登录二维码辅助渲染库
CONFIG_PACKAGE_luci-lib-uqr=y
# 完整的网络管理员控制面板模块
CONFIG_PACKAGE_luci-mod-admin-full=y
# 网络连接与配置交互管理模块
CONFIG_PACKAGE_luci-mod-network=y
# 状态与资源展示面板模块
CONFIG_PACKAGE_luci-mod-status=y
# 系统时间、备份与升级控制模块
CONFIG_PACKAGE_luci-mod-system=y
# 启用网页端配置 IPv6 协议支持
CONFIG_PACKAGE_luci-proto-ipv6=y
# 启用网页端配置 PPPoE 拨号支持
CONFIG_PACKAGE_luci-proto-ppp=y
# 全局中文语言支持
CONFIG_LUCI_LANG_zh_Hans=y
# 【来自第二份配置】自动精简网页 HTML/JS 体积，加速页面加载
CONFIG_LUCI_SRCDIET=y
# 基础后台系统设置中文汉化包
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
# 防火墙控制页中文汉化包
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
# 保留经典 Bootstrap 网页主题
CONFIG_PACKAGE_luci-theme-bootstrap=y

# --- 【以下美化主题完全来自第二份配置】 ---
# 极受赞誉的现代化 Argon 美化主题配置
CONFIG_PACKAGE_luci-theme-argon=y

# ==============================================================================
# LuCI Web 应用管理插件及中文汉化 (两份共有，【第二份配置】进行了极大补充)
# ==============================================================================
# --- 【核心定制插件（两份共有，第一份重点适配，第二份包含）】 ---
# 您的 Airoha AN7581 NPU 核心硬件转发控制面板
CONFIG_PACKAGE_luci-app-airoha-npu=y
# 您的 AN7581 CPU 运行温度及工作频率调节面板
CONFIG_PACKAGE_luci-app-cpufreq=y
# NPU 转发面板中文汉化包
CONFIG_PACKAGE_luci-i18n-airoha-npu-zh-cn=y

# --- 【以下实用系统插件完全来自第二份配置】 ---
# Argon 主题壁纸背景、毛玻璃模糊效果配置插件
CONFIG_PACKAGE_luci-app-argon-config=y
# 定时计划自动重启系统控制插件
CONFIG_PACKAGE_luci-app-autoreboot=y
# 防火墙规则与端口映射管理插件
CONFIG_PACKAGE_luci-app-firewall=y
# 替代 opkg/apk 的可视化网页软件包安装面板
CONFIG_PACKAGE_luci-app-package-manager=y
# 网页端一键清理并释放系统空闲内存插件
CONFIG_PACKAGE_luci-app-ramfree=y
# 免 SSH、免客户端直接在浏览器运行终端的网页版后台
CONFIG_PACKAGE_luci-app-ttyd=y
# LuCI Web 服务器 (uhttpd) 端口与证书可视化参数修改插件
CONFIG_PACKAGE_luci-app-uhttpd=y
# UPnP 内网游戏设备自动端口映射后台
CONFIG_PACKAGE_luci-app-upnp=y
# 可视化点击“网络唤醒”触发内网 PC 开机的管理插件
CONFIG_PACKAGE_luci-app-wol=y
# 完美兼容 nftables 的自动 UPnP 后端守护服务
CONFIG_PACKAGE_miniupnpd-nftables=y

# --- 【以下是第二份配置补全的各应用插件中文包】 ---
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ramfree-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-uhttpd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y

# ==============================================================================
# 固件全局出厂首开设置 (两份配置共有)
# ==============================================================================
# 官方通用初始默认配置文件
CONFIG_PACKAGE_default-settings=y
# 中国区域本土化出厂预设配置
CONFIG_PACKAGE_default-settings-chn=y

# ==============================================================================
# libcurl 请求库详细底层协议参数配置 (完全来自【第二份配置】)
# ==============================================================================
CONFIG_LIBCURL_COOKIES=y
CONFIG_LIBCURL_CRYPTO_AUTH=y
CONFIG_LIBCURL_FILE=y
CONFIG_LIBCURL_FTP=y
CONFIG_LIBCURL_HTTP=y
CONFIG_LIBCURL_HTTP2=y
CONFIG_LIBCURL_HTTP_AUTH=y
CONFIG_LIBCURL_OPENSSL=y
CONFIG_LIBCURL_PROXY=y
CONFIG_LIBCURL_TFTP=y
CONFIG_LIBCURL_THREADED_RESOLVER=y
CONFIG_LIBCURL_TLS_SRP=y
CONFIG_LIBCURL_UNIX_SOCKETS=y

# ==============================================================================
# ZRAM 极速虚拟内存交换分区优化 (完全来自【第二份配置】)
# ==============================================================================
# 启用 ZRAM 内核压缩交换分区支持
CONFIG_PACKAGE_kmod-zram=y
# 启用基于 ZRAM 的高速虚拟 Swap 功能
CONFIG_PACKAGE_zram-swap=y
# 启用极速 LZ4 算法压缩支持
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
# 启用高压缩比 LZ4HC 算法支持
CONFIG_KERNEL_ZRAM_BACKEND_LZ4HC=y
# 兼容传统 LZO 压缩算法支持
CONFIG_KERNEL_ZRAM_BACKEND_LZO=y
# 启用高性能更均衡的 ZSTD 压缩算法
CONFIG_KERNEL_ZRAM_BACKEND_ZSTD=y
# 设定 LZ4 为默认工作压缩算法
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y

# ==============================================================================
# 编译及系统运行级深度优化配置 (完全来自【第二份配置】)
# ==============================================================================
# 高性能 ZSTD 压缩模块使用最高优化编译加速
CONFIG_ZSTD_OPTIMIZE_O3=y
# 正则表达式 PCRE2 启用高速 JIT 即时编译加速
CONFIG_PCRE2_JIT_ENABLED=y
# Perl 语言精简优化 (剥离脚本内的大量代码注释)
CONFIG_PERL_NOCOMMENT=y
# 允许 Perl 脚本执行多线程并发处理
CONFIG_PERL_THREADS=y
# Btrfs 分区维护工具加入 ZSTD 高速算法支持
CONFIG_BTRFS_PROGS_ZSTD=y
# 全新 Lua-ECO 高速异步框架选用 mbedTLS 加密库
CONFIG_LUA_ECO_MBEDTLS=y

# ==============================================================================
# 明确关闭的软件包 (完全来自【第二份配置】)
# ==============================================================================
# CONFIG_LUA_ECO_OPENSSL is not set
# CONFIG_NODEJS_HOST_BIN is not set
# CONFIG_WIFI_SCRIPTS_UCODE is not set

# 禁用 Passwall 相关子依赖
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Server is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Simple_Obfs is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Geoview is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray is not set

# 禁用云同步组件附加子项
# CONFIG_PACKAGE_luci-app-rclone_INCLUDE_rclone-ng is not set
# CONFIG_PACKAGE_luci-app-rclone_INCLUDE_rclone-webui is not set

# 禁用冗余网络后台组件
# CONFIG_PACKAGE_chinadns-ng is not set
# CONFIG_PACKAGE_ddns-go is not set
# CONFIG_PACKAGE_dns2socks is not set
# CONFIG_PACKAGE_frpc is not set
# CONFIG_PACKAGE_geoview is not set
# CONFIG_PACKAGE_haproxy is not set
# CONFIG_PACKAGE_hd-idle is not set
# CONFIG_PACKAGE_ipt2socks is not set
# CONFIG_PACKAGE_ksmbd-server is not set
# CONFIG_PACKAGE_microsocks is not set
# CONFIG_PACKAGE_natmap is not set
# CONFIG_PACKAGE_sing-box is not set
# CONFIG_PACKAGE_vlmcsd is not set
# CONFIG_PACKAGE_vsftpd is not set
# CONFIG_PACKAGE_wsdd2 is not set
# CONFIG_PACKAGE_zerotier is not set
# CONFIG_PACKAGE_zoneinfo-core is not set
# CONFIG_PACKAGE_zoneinfo-simple is not set

# 彻底禁用不需要的 Watchcat 看门狗断网自动重启插件
# CONFIG_PACKAGE_luci-app-watchcat is not set
# CONFIG_PACKAGE_luci-i18n-watchcat-zh-cn is not set
# CONFIG_PACKAGE_watchcat is not set
